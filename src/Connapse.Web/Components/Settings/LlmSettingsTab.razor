@using Connapse.Core
@using Connapse.Core.Interfaces
@using Connapse.Storage.ConnectionTesters

<EditForm Model="@localSettings" OnValidSubmit="HandleSubmit">
    <DataAnnotationsValidator />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Provider</label>
            <InputSelect @bind-Value="localSettings.Provider" class="form-select" @bind-Value:after="OnProviderChanged">
                <option value="Ollama">Ollama</option>
                <option value="OpenAI">OpenAI</option>
                <option value="AzureOpenAI">Azure OpenAI</option>
                <option value="Anthropic">Anthropic</option>
            </InputSelect>
        </div>

        @if (IsOllama)
        {
            <div class="col-md-6">
                <label class="form-label">Model</label>
                <InputText @bind-Value="localSettings.Model" class="form-control" placeholder="llama3.2" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Base URL</label>
                <InputText @bind-Value="localSettings.BaseUrl" class="form-control" placeholder="http://localhost:11434" />
            </div>
        }
        else if (IsOpenAi)
        {
            <div class="col-md-6">
                <label class="form-label">API Key</label>
                <InputText @bind-Value="localSettings.ApiKey" type="password" class="form-control" placeholder="sk-..." />
            </div>

            <div class="col-md-6">
                <label class="form-label">Model</label>
                <InputText @bind-Value="localSettings.Model" class="form-control" placeholder="gpt-4o" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Base URL</label>
                <InputText @bind-Value="localSettings.BaseUrl" class="form-control" placeholder="https://api.openai.com/v1" />
                <small class="form-text text-muted">Override for OpenAI-compatible endpoints (Groq, Together, etc.)</small>
            </div>
        }
        else if (IsAzureOpenAi)
        {
            <div class="col-md-6">
                <label class="form-label">API Key</label>
                <InputText @bind-Value="localSettings.ApiKey" type="password" class="form-control" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Endpoint URL</label>
                <InputText @bind-Value="localSettings.BaseUrl" class="form-control" placeholder="https://your-resource.openai.azure.com" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Deployment Name</label>
                <InputText @bind-Value="localSettings.AzureDeploymentName" class="form-control" placeholder="gpt-4o" />
                <small class="form-text text-muted">The deployment name in your Azure OpenAI resource</small>
            </div>
        }
        else if (IsAnthropic)
        {
            <div class="col-md-6">
                <label class="form-label">API Key</label>
                <InputText @bind-Value="localSettings.ApiKey" type="password" class="form-control" placeholder="sk-ant-..." />
            </div>

            <div class="col-md-6">
                <label class="form-label">Model</label>
                <InputText @bind-Value="localSettings.Model" class="form-control" placeholder="claude-sonnet-4-20250514" />
            </div>
        }

        <div class="col-md-6">
            <label class="form-label">Temperature</label>
            <InputNumber @bind-Value="localSettings.Temperature" class="form-control" step="0.1" min="0" max="2" />
            <small class="form-text text-muted">Randomness (0.0-2.0)</small>
        </div>

        <div class="col-md-6">
            <label class="form-label">Max Tokens</label>
            <InputNumber @bind-Value="localSettings.MaxTokens" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Timeout (seconds)</label>
            <InputNumber @bind-Value="localSettings.TimeoutSeconds" class="form-control" />
        </div>

        <div class="col-12">
            <label class="form-label">System Prompt</label>
            <InputTextArea @bind-Value="localSettings.SystemPrompt" class="form-control" rows="4" placeholder="Optional system prompt prefix" />
        </div>

        <div class="col-12 mt-4">
            <button type="submit" class="btn btn-primary me-2">
                <span class="bi-save me-1"></span> Save Changes
            </button>
            <button type="button" class="btn btn-secondary me-2" @onclick="Reset">
                <span class="bi-arrow-counterclockwise me-1"></span> Reset
            </button>
            <button type="button" class="btn btn-info" @onclick="TestConnection" disabled="@isTestingConnection">
                @if (isTestingConnection)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    <span>Testing...</span>
                }
                else
                {
                    <span class="bi-plug me-1"></span>
                    <span>Test Connection</span>
                }
            </button>
        </div>

        @if (!string.IsNullOrEmpty(testMessage))
        {
            <div class="col-12 mt-3">
                <div class="alert @(testSuccess ? "alert-success" : "alert-danger") alert-dismissible fade show" role="alert">
                    <span class="@(testSuccess ? "bi-check-circle" : "bi-x-circle") me-2"></span>
                    @testMessage
                    <button type="button" class="btn-close" @onclick="@(() => testMessage = null)"></button>
                </div>
            </div>
        }
    </div>
</EditForm>

@inject OllamaConnectionTester OllamaTester
@inject OpenAiLlmConnectionTester OpenAiLlmTester
@inject AzureOpenAiLlmConnectionTester AzureOpenAiLlmTester
@inject AnthropicConnectionTester AnthropicTester

@code {
    [Parameter]
    public LlmSettings Settings { get; set; } = new();

    [Parameter]
    public EventCallback<LlmSettings> OnSave { get; set; }

    private LlmSettings localSettings = new();
    private bool isTestingConnection;
    private string? testMessage;
    private bool testSuccess;

    private bool IsOllama => localSettings.Provider is null or "Ollama";
    private bool IsOpenAi => localSettings.Provider == "OpenAI";
    private bool IsAzureOpenAi => localSettings.Provider == "AzureOpenAI";
    private bool IsAnthropic => localSettings.Provider == "Anthropic";

    protected override void OnParametersSet()
    {
        localSettings = Settings with { };
    }

    private void OnProviderChanged()
    {
        switch (localSettings.Provider)
        {
            case "OpenAI":
                if (string.IsNullOrWhiteSpace(localSettings.Model) || localSettings.Model == "llama3.2")
                    localSettings.Model = "gpt-4o";
                if (localSettings.BaseUrl == "http://localhost:11434")
                    localSettings.BaseUrl = null;
                if (localSettings.MaxTokens == 2000)
                    localSettings.MaxTokens = 4096;
                break;

            case "AzureOpenAI":
                if (string.IsNullOrWhiteSpace(localSettings.Model) || localSettings.Model == "llama3.2")
                    localSettings.Model = "gpt-4o";
                if (localSettings.BaseUrl == "http://localhost:11434")
                    localSettings.BaseUrl = null;
                if (localSettings.MaxTokens == 2000)
                    localSettings.MaxTokens = 4096;
                break;

            case "Anthropic":
                if (string.IsNullOrWhiteSpace(localSettings.Model) || localSettings.Model == "llama3.2")
                    localSettings.Model = "claude-sonnet-4-20250514";
                if (localSettings.BaseUrl == "http://localhost:11434")
                    localSettings.BaseUrl = null;
                if (localSettings.MaxTokens == 2000)
                    localSettings.MaxTokens = 4096;
                break;

            case "Ollama":
            default:
                if (localSettings.Model is "gpt-4o" or "claude-sonnet-4-20250514")
                    localSettings.Model = "llama3.2";
                if (string.IsNullOrWhiteSpace(localSettings.BaseUrl))
                    localSettings.BaseUrl = "http://localhost:11434";
                if (localSettings.MaxTokens == 4096)
                    localSettings.MaxTokens = 2000;
                break;
        }
    }

    private async Task HandleSubmit()
    {
        await OnSave.InvokeAsync(localSettings);
    }

    private void Reset()
    {
        localSettings = Settings with { };
    }

    private async Task TestConnection()
    {
        isTestingConnection = true;
        testMessage = null;
        StateHasChanged();

        try
        {
            IConnectionTester tester = localSettings.Provider switch
            {
                "OpenAI" => OpenAiLlmTester,
                "AzureOpenAI" => AzureOpenAiLlmTester,
                "Anthropic" => AnthropicTester,
                _ => OllamaTester
            };

            var result = await tester.TestConnectionAsync(
                localSettings, TimeSpan.FromSeconds(10));

            testSuccess = result.Success;
            testMessage = result.Message;
        }
        catch (Exception ex)
        {
            testSuccess = false;
            testMessage = $"Test failed: {ex.Message}";
        }
        finally
        {
            isTestingConnection = false;
            StateHasChanged();
        }
    }
}
