    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        canEdit = !authState.User.IsInRole("Viewer");

        // Subscribe to in-process progress notifications instead of creating a
        // server-to-server SignalR client (which has no auth cookies and fails negotiate).
        ProgressNotifier.ProgressReceived += OnProgressReceived;

        // Subscribe to real-time file-list changes from the filesystem watcher.
        FileChangeNotifier.FileChanged += OnFileChanged;

        await LoadContainer();
        await LoadEntries();
    }

    private async void OnProgressReceived(IngestionProgressUpdate progress)
    {
        if (_disposed) return;
        try
        {
            await HandleIngestionProgress(progress);
        }
        catch (Exception)
        {
            // Swallow all exceptions from async void to prevent crashing the Blazor circuit.
            // Exceptions can occur when the component is disposed between the guard check and
            // the awaited call, or during transient failures under heavy ingestion load.
        }
    }

    /// <summary>
    /// Fired by ConnectorWatcherService when a file is added or deleted from a
    /// Filesystem container. Adds/removes the entry in real time without a full reload.
    /// </summary>
    private async void OnFileChanged(FileBrowserFileEvent ev)
    {
        if (_disposed) return;
        if (ev.ContainerId != ContainerId) return;

        try
        {
            await InvokeAsync(() =>
            {
            if (ev.IsDeleted)
            {
                // Remove by document ID (preferred) or by matching virtual path
                entries.RemoveAll(e =>
                    (ev.DocumentId is not null && e.Id == ev.DocumentId) ||
                    string.Equals(e.Path, ev.VirtualPath, StringComparison.OrdinalIgnoreCase));

                if (selectedBrowseEntry is not null &&
                    (string.Equals(selectedBrowseEntry.Path, ev.VirtualPath, StringComparison.OrdinalIgnoreCase) ||
                     (ev.DocumentId is not null && selectedBrowseEntry.Id == ev.DocumentId)))
                {
                    selectedFile = null;
                    selectedBrowseEntry = null;
                }
            }
            else
            {
                // Only show the file if it lives in the currently browsed directory.
                // e.g. VirtualPath "/subdir/file.pdf" → dir "/subdir/"
                //      VirtualPath "/file.pdf"         → dir "/"
                var trimmed = ev.VirtualPath.TrimStart('/');
                var lastSlash = trimmed.LastIndexOf('/');
                var fileVirtualDir = lastSlash < 0 ? "/" : "/" + trimmed[..lastSlash] + "/";
                var normalizedCurrentPath = currentPath == "/" ? "/" : "/" + currentPath.Trim('/') + "/";

                if (!string.Equals(fileVirtualDir, normalizedCurrentPath, StringComparison.OrdinalIgnoreCase))
                    return;

                // Update existing entry (re-ingestion) or insert a new one (new file)
                var existingIdx = entries.FindIndex(e =>
                    string.Equals(e.Path, ev.VirtualPath, StringComparison.OrdinalIgnoreCase) ||
                    (ev.DocumentId is not null && e.Id == ev.DocumentId));

                if (existingIdx >= 0)
                {
                    entries[existingIdx] = entries[existingIdx] with { Status = "Queued", Id = ev.DocumentId };
                }
                else
                {
                    var newEntry = new BrowseEntryDto(
                        ev.FileName,
                        ev.VirtualPath,
                        false,
                        null,
                        DateTime.UtcNow,
                        "Queued",
                        ev.DocumentId);

                    var insertIdx = entries.FindIndex(e =>
                        !e.IsFolder &&
                        string.Compare(e.Name, ev.FileName, StringComparison.OrdinalIgnoreCase) > 0);
                    if (insertIdx < 0) insertIdx = entries.Count;
                    entries.Insert(insertIdx, newEntry);
                }
            }

            StateHasChanged();
        });
        }
        catch (Exception)
        {
            // Swallow to prevent async void from crashing the Blazor circuit.
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (canEdit && AllowUpload && !jsInitialized && !isLoading)
        {
            try
            {
                jsModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/fileDrop.js");
                dotNetRef ??= DotNetObjectReference.Create(this);
                // Extract the path prefix from NavigationManager so the JS fetch
                // includes it — deployments may use path-based routing that
                // requires the prefix for correct authorization.
                var basePath = new Uri(Navigation.BaseUri).AbsolutePath.TrimEnd('/');
                await jsModule.InvokeVoidAsync("initializeDropZone", "fileDropZone", dotNetRef, ContainerId, basePath);
                jsInitialized = true;
            }
            catch { /* Will retry on next render */ }
        }
    }

    private async Task LoadContainer()
    {
        try
        {
            if (Guid.TryParse(ContainerId, out var containerId))
            {
                container = await ContainerStore.GetAsync(containerId);
                if (container is null)
                    errorMessage = "Container not found.";
                else
                    filesystemConfig = ParseFilesystemConfig(container);
            }
            else
                errorMessage = "Invalid container ID.";
        }
        catch
        {
            // Transient error (e.g. DB timeout under ingestion load) — don't clobber the
            // container that was already loaded; just log silently and leave state as-is.
        }
    }

    private static FilesystemConnectorConfig? ParseFilesystemConfig(Container? container)
    {
        if (container?.ConnectorType != ConnectorType.Filesystem || string.IsNullOrEmpty(container.ConnectorConfig))
            return null;
        try
        {
            return System.Text.Json.JsonSerializer.Deserialize<FilesystemConnectorConfig>(
                container.ConnectorConfig,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
        }
        catch { return null; }
    }

    private async Task LoadEntries()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            entries = await FetchBrowseEntries();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load files: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Refreshes the file list without showing the loading spinner.
    /// Preserves optimistic entries for in-flight ingestion jobs so files
    /// don't disappear and reappear during batch uploads.
    /// </summary>
    private async Task RefreshEntries()
    {
        try
        {
            var serverEntries = await FetchBrowseEntries();

            // Preserve in-flight entries (active ingestion jobs not yet in server state)
            var inFlightDocIds = new HashSet<string>(jobToDocumentId.Values);
            var serverIds = new HashSet<string>(
                serverEntries.Where(e => e.Id is not null).Select(e => e.Id!));

            var preserved = entries
                .Where(e => e.Id is not null
                          && inFlightDocIds.Contains(e.Id)
                          && !serverIds.Contains(e.Id))
                .ToList();

            entries = serverEntries;

            // Re-insert preserved in-flight entries in sorted position
            foreach (var entry in preserved)
            {
                var insertIdx = entries.FindIndex(e =>
                    !e.IsFolder && string.Compare(e.Name, entry.Name, StringComparison.OrdinalIgnoreCase) > 0);
                if (insertIdx < 0) insertIdx = entries.Count;
                entries.Insert(insertIdx, entry);
            }
        }
        catch { /* Silently ignore refresh failures */ }
    }

    private async Task<List<BrowseEntryDto>> FetchBrowseEntries()
    {
        if (!Guid.TryParse(ContainerId, out var containerId))
            return new();

        // For Filesystem containers, enumerate directly from disk and overlay DB status.
        if (container?.ConnectorType == ConnectorType.Filesystem)
        {
            try
            {
                var fsConnector = (FilesystemConnector)ConnectorFactory.Create(container);
                return await FetchFilesystemBrowseEntries(fsConnector, containerId);
            }
            catch { /* Fall through to DB listing if connector config is invalid */ }
        }

        var browsePath = PathUtilities.NormalizeFolderPath(currentPath);
        var result = new List<BrowseEntryDto>();

        var folders = await FolderStore.ListAsync(containerId, parentPath: browsePath);
        foreach (var folder in folders)
        {
            var folderName = PathUtilities.GetFileName(folder.Path.TrimEnd('/'));
            result.Add(new BrowseEntryDto(folderName, folder.Path, IsFolder: true, SizeBytes: null, LastModified: folder.CreatedAt, Status: null, Id: folder.Id));
        }

        var documents = await DocumentStore.ListAsync(containerId, pathPrefix: browsePath);
        foreach (var doc in documents)
        {
            var docParent = PathUtilities.GetParentPath(doc.Path);
            if (!string.Equals(docParent, browsePath, StringComparison.OrdinalIgnoreCase))
                continue;

            result.Add(new BrowseEntryDto(doc.FileName, doc.Path, IsFolder: false, SizeBytes: doc.SizeBytes, LastModified: doc.CreatedAt, Status: doc.Metadata.GetValueOrDefault("Status"), Id: doc.Id));
        }

        result.Sort((a, b) =>
        {
            if (a.IsFolder != b.IsFolder) return a.IsFolder ? -1 : 1;
            return string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase);
        });

        return result;
    }

    /// <summary>
    /// For Filesystem containers: list directories and files directly from disk.
    /// Overlays document status from the DB by matching absolute paths.
    /// </summary>
    private async Task<List<BrowseEntryDto>> FetchFilesystemBrowseEntries(FilesystemConnector connector, Guid containerId)
    {
        var rootPath = connector.RootPath;

        // Convert the current virtual path (/subfolder/) to an absolute disk path
        var absCurrentPath = currentPath == "/"
            ? rootPath
            : Path.Combine(rootPath, currentPath.TrimStart('/').TrimEnd('/').Replace('/', Path.DirectorySeparatorChar));

        var result = new List<BrowseEntryDto>();

        if (!Directory.Exists(absCurrentPath))
            return result;

        // Subdirectories → virtual path (/subfolder/) for navigation
        foreach (var dir in Directory.EnumerateDirectories(absCurrentPath))
        {
            var info = new DirectoryInfo(dir);
            var rel = Path.GetRelativePath(rootPath, dir).Replace('\\', '/');
            result.Add(new BrowseEntryDto(info.Name, "/" + rel + "/", true, null, info.LastWriteTimeUtc, null, null));
        }

        // Files → look up DB document by virtual path to get ingestion status
        foreach (var file in Directory.EnumerateFiles(absCurrentPath))
        {
            var info = new FileInfo(file);
            var rel = Path.GetRelativePath(rootPath, file).Replace('\\', '/');
            var virtualPath = "/" + rel;
            var doc = await DocumentStore.GetByPathAsync(containerId, virtualPath);
            result.Add(new BrowseEntryDto(
                info.Name,
                virtualPath,
                false,
                info.Length,
                info.LastWriteTimeUtc,
                doc?.Metadata.GetValueOrDefault("Status"),
                doc?.Id));
        }

        result.Sort((a, b) =>
        {
            if (a.IsFolder != b.IsFolder) return a.IsFolder ? -1 : 1;
            return string.Compare(a.Name, b.Name, StringComparison.OrdinalIgnoreCase);
        });

        return result;
    }

