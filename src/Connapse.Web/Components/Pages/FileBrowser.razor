    private List<BreadcrumbItem> GetBreadcrumbs()
    {
        if (currentPath == "/") return new();

        var parts = currentPath.Trim('/').Split('/');
        var crumbs = new List<BreadcrumbItem>();
        var accumulated = "/";

        foreach (var part in parts)
        {
            if (string.IsNullOrEmpty(part)) continue;
            accumulated += part + "/";
            crumbs.Add(new BreadcrumbItem(part, accumulated));
        }

        return crumbs;
    }

    // JS interop callbacks for drag-and-drop uploads
    [JSInvokable]
    public string GetCurrentPath() => currentPath;

    [JSInvokable]
    public async Task HandleDropUploadResult(string resultJson)
    {
        var result = System.Text.Json.JsonSerializer.Deserialize<UploadResponseDto>(
            resultJson,
            new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

        if (result is not null)
        {
            foreach (var doc in result.Documents)
            {
                var newEntry = new BrowseEntryDto(
                    Name: doc.FileName,
                    Path: doc.Path,
                    IsFolder: false,
                    SizeBytes: doc.SizeBytes,
                    LastModified: DateTime.UtcNow,
                    Status: "Queued",
                    Id: doc.DocumentId);

                // Deduplicate by ID or path — a cloud sync poll or filesystem watcher may have
                // already inserted an entry for the same file with a different document ID.
                var existingIdx = entries.FindIndex(e =>
                    e.Id == doc.DocumentId ||
                    (!e.IsFolder && string.Equals(e.Path, doc.Path, StringComparison.OrdinalIgnoreCase)));

                if (existingIdx >= 0)
                {
                    // Update the existing entry to use the canonical upload document ID
                    entries[existingIdx] = newEntry;
                }
                else
                {
                    var insertIdx = entries.FindIndex(e => !e.IsFolder && string.Compare(e.Name, doc.FileName, StringComparison.OrdinalIgnoreCase) > 0);
                    if (insertIdx < 0) insertIdx = entries.Count;
                    entries.Insert(insertIdx, newEntry);
                }

                if (doc.JobId is not null)
                    jobToDocumentId[doc.JobId] = doc.DocumentId;
            }
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task HandleDropUploadError(string error)
    {
        errorMessage = $"Drop upload failed: {error}";
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleIngestionProgress(IngestionProgressUpdate progress)
    {
        await InvokeAsync(() =>
        {
            // Prefer the tracked UI-upload mapping; fall back to the document ID embedded
            // in the progress update (populated for watcher-originated jobs).
            if (!jobToDocumentId.TryGetValue(progress.JobId, out var documentId))
            {
                // Only handle watcher jobs that belong to this container
                if (progress.ContainerId != ContainerId || string.IsNullOrEmpty(progress.DocumentId))
                    return;
                documentId = progress.DocumentId;
            }

            // Map ingestion state to a display status
            var displayStatus = progress.State switch
            {
                "Completed" => "Ready",
                "Failed" => "Error",
                _ => progress.State // Queued, Processing, etc.
            };

            // Update the matching entry's status in the file list
            var idx = entries.FindIndex(e => e.Id == documentId);
            if (idx >= 0)
                entries[idx] = entries[idx] with { Status = displayStatus };

            // Remove finished UI-upload job from tracking.
            // Trigger a full refresh when all tracked jobs are done (Count hits 0).
            // For watcher-originated jobs (not in jobToDocumentId), Count is always 0, so this
            // also acts as a fallback for when the in-place update above can't find the entry
            // (e.g. page loaded while a job was already in progress and the entry has no Id yet).
            // The watcher no longer re-queues existing files (ConnectorWatcherService Created fix),
            // so RefreshEntries() here can't produce duplicate entries or flicker.
            if (progress.State is "Completed" or "Failed")
            {
                jobToDocumentId.Remove(progress.JobId);

                if (jobToDocumentId.Count == 0)
                {
                    _ = InvokeAsync(async () =>
                    {
                        try
                        {
                            await RefreshEntries();
                            await LoadContainer();
                        }
                        finally
                        {
                            StateHasChanged();
                        }
                    });
                }
            }

            StateHasChanged();
        });
    }

    // Create folder
    private void ShowCreateFolderModal()
    {
        showFolderModal = true;
        newFolderName = "";
        folderError = null;
    }

    private void HideFolderModal() => showFolderModal = false;

    private async Task CreateFolder()
    {
        if (string.IsNullOrWhiteSpace(newFolderName))
        {
            folderError = "Folder name is required.";
            return;
        }

        isCreatingFolder = true;
        folderError = null;

        try
        {
            if (!Guid.TryParse(ContainerId, out var containerId))
            {
                folderError = "Invalid container ID.";
                return;
            }

            var folderPath = PathUtilities.NormalizeFolderPath(currentPath + newFolderName.Trim().TrimEnd('/') + "/");

            if (container?.ConnectorType == ConnectorType.Filesystem)
            {
                // Filesystem containers: create the directory on disk; no DB folder record needed.
                try
                {
                    var fsConnector = (FilesystemConnector)ConnectorFactory.Create(container);
                    var relPath = folderPath.TrimStart('/').TrimEnd('/').Replace('/', Path.DirectorySeparatorChar);
                    Directory.CreateDirectory(Path.Combine(fsConnector.RootPath, relPath));
                }
                catch (Exception ex)
                {
                    folderError = $"Failed to create directory: {ex.Message}";
                    return;
                }
            }
            else
            {
                if (await FolderStore.ExistsAsync(containerId, folderPath))
                {
                    folderError = $"Folder '{folderPath}' already exists.";
                    return;
                }
                await FolderStore.CreateAsync(containerId, folderPath);
            }

            showFolderModal = false;
            await RefreshEntries();
        }
        catch (Exception ex)
        {
            folderError = ex.Message;
        }
        finally
        {
            isCreatingFolder = false;
        }
    }

    // Delete entry
    private void ConfirmDeleteEntry(BrowseEntryDto entry)
    {
        entryToDelete = entry;
        deleteError = null;
    }

    private void CancelDeleteEntry() => entryToDelete = null;

    private async Task DeleteEntry()
    {
        if (entryToDelete is null) return;

        isDeletingEntry = true;
        deleteError = null;

        try
        {
            if (!Guid.TryParse(ContainerId, out var containerId))
            {
                deleteError = "Invalid container ID.";
                return;
            }

            if (entryToDelete.IsFolder)
            {
                await DeleteFolderEntry(containerId, entryToDelete);
            }
            else
            {
                await DeleteFileEntry(entryToDelete);
            }

            entryToDelete = null;
            await RefreshEntries();
            await LoadContainer();
        }
        catch (Exception ex)
        {
            deleteError = ex.Message;
        }
        finally
        {
            isDeletingEntry = false;
        }
    }

    private async Task DeleteFileEntry(BrowseEntryDto entry)
    {
        if (entry.Id is null) return;

        await IngestionQueue.CancelJobForDocumentAsync(entry.Id);
        await DocumentStore.DeleteAsync(entry.Id);

        try
        {
            if (!string.IsNullOrEmpty(entry.Path))
            {
                if (container?.ConnectorType == ConnectorType.Filesystem)
                {
                    // entry.Path is a virtual path (/subfolder/file.pdf); connector resolves it to absolute
                    var fsConnector = (FilesystemConnector)ConnectorFactory.Create(container);
                    await fsConnector.DeleteFileAsync(entry.Path.TrimStart('/'));
                }
                else
                {
                    await FileSystem.DeleteAsync(entry.Path);
                }
            }
        }
        catch { /* File already deleted or not found */ }

        if (selectedBrowseEntry?.Id == entry.Id)
        {
            selectedFile = null;
            selectedBrowseEntry = null;
        }
    }

    private async Task DeleteFolderEntry(Guid containerId, BrowseEntryDto entry)
    {
        var normalizedPath = PathUtilities.NormalizeFolderPath(entry.Path);

        if (container?.ConnectorType == ConnectorType.Filesystem)
        {
            // Delete the directory from disk; the watcher will remove associated DB docs async,
            // but we also clean them up here for immediate UI consistency.
            try
            {
                var fsConnector = (FilesystemConnector)ConnectorFactory.Create(container);
                var relPath = normalizedPath.TrimStart('/').TrimEnd('/').Replace('/', Path.DirectorySeparatorChar);
                var absPath = Path.Combine(fsConnector.RootPath, relPath);
                if (Directory.Exists(absPath))
                    Directory.Delete(absPath, recursive: true);
            }
            catch { /* Directory already deleted or not found */ }

            // Cancel in-flight jobs and remove documents from DB
            var fsDocs = await DocumentStore.ListAsync(containerId, pathPrefix: normalizedPath);
            foreach (var doc in fsDocs)
            {
                await IngestionQueue.CancelJobForDocumentAsync(doc.Id);
                await DocumentStore.DeleteAsync(doc.Id);
            }
        }
        else
        {
            var docs = await DocumentStore.ListAsync(containerId, pathPrefix: normalizedPath);

            foreach (var doc in docs)
                await IngestionQueue.CancelJobForDocumentAsync(doc.Id);

            await FolderStore.DeleteAsync(containerId, normalizedPath);

            foreach (var doc in docs)
            {
                try
                {
                    if (!string.IsNullOrEmpty(doc.Path))
                        await FileSystem.DeleteAsync(doc.Path);
                }
                catch { /* File already deleted or not found */ }
            }
        }
    }

    // Multi-select helpers
    private string GetEntryKey(BrowseEntryDto entry) => entry.Id ?? entry.Path;

    private bool IsSelected(BrowseEntryDto entry) => selectedEntryKeys.Contains(GetEntryKey(entry));

    private bool AllSelected => entries.Count > 0 && entries.All(e => selectedEntryKeys.Contains(GetEntryKey(e)));

    private void ToggleSelection(BrowseEntryDto entry)
    {
        var key = GetEntryKey(entry);
        if (!selectedEntryKeys.Remove(key))
            selectedEntryKeys.Add(key);
    }

    private void ToggleSelectAll()
    {
        if (AllSelected)
            selectedEntryKeys.Clear();
        else
            foreach (var entry in entries)
                selectedEntryKeys.Add(GetEntryKey(entry));
    }

    private void ClearSelection() => selectedEntryKeys.Clear();

    private void ShowBulkDeleteConfirmation()
    {
        if (selectedEntryKeys.Count > 0)
        {
            showBulkDeleteModal = true;
            bulkDeleteError = null;
        }
    }

    private void CancelBulkDelete() => showBulkDeleteModal = false;

    private async Task BulkDeleteSelected()
    {
        isDeletingBulk = true;
        bulkDeleteError = null;

        try
        {
            if (!Guid.TryParse(ContainerId, out var containerId))
            {
                bulkDeleteError = "Invalid container ID.";
                return;
            }

            var toDelete = entries.Where(e => selectedEntryKeys.Contains(GetEntryKey(e))).ToList();
            var errors = new List<string>();

            foreach (var entry in toDelete)
            {
                try
                {
                    if (entry.IsFolder)
                        await DeleteFolderEntry(containerId, entry);
                    else
                        await DeleteFileEntry(entry);
                }
                catch (Exception ex)
                {
                    errors.Add($"{entry.Name}: {ex.Message}");
                }
            }

            if (errors.Count > 0)
            {
                bulkDeleteError = $"Failed to delete {errors.Count} item(s): {string.Join("; ", errors)}";
            }
            else
            {
                showBulkDeleteModal = false;
                selectedEntryKeys.Clear();
            }

            await RefreshEntries();
            await LoadContainer();
        }
        catch (Exception ex)
        {
            bulkDeleteError = ex.Message;
        }
        finally
        {
            isDeletingBulk = false;
        }
    }

    // Helpers
    private static string FormatFileSize(long bytes)
    {
        string[] sizes = ["B", "KB", "MB", "GB"];
        double len = bytes;
        int order = 0;
        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }
        return $"{len:0.##} {sizes[order]}";
    }

    private static string GetStatusBadgeClass(string status) => status switch
    {
        "Ready" => "bg-success",
        "Processing" => "bg-info",
        "Queued" => "bg-secondary",
        "Pending" => "bg-secondary",
        "Error" or "Failed" => "bg-danger",
        _ => "bg-secondary"
    };

    // Settings tab
    private async Task ShowSettingsTab()
    {
        activeTab = "settings";
        settingsSaved = false;
        settingsError = null;
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        if (!Guid.TryParse(ContainerId, out var containerId)) return;

        settingsLoading = true;
        try
        {
            // Load global defaults via resolver (no container override = just global)
            var globalChunking = await SettingsResolver.GetChunkingSettingsAsync(containerId);
            globalChunkingStrategy = globalChunking.Strategy;
            globalMaxChunkSize = globalChunking.MaxChunkSize;
            globalOverlap = globalChunking.Overlap;

            var globalEmbedding = await SettingsResolver.GetEmbeddingSettingsAsync(containerId);
            globalEmbeddingProvider = globalEmbedding.Provider;
            globalEmbeddingModel = globalEmbedding.Model;
            globalEmbeddingDimensions = globalEmbedding.Dimensions;

            var globalSearch = await SettingsResolver.GetSearchSettingsAsync(containerId);
            globalSearchMode = globalSearch.Mode;
            globalTopK = globalSearch.TopK;
            globalMinScore = globalSearch.MinimumScore;

            // Load current container overrides
            var overrides = await ContainerStore.GetSettingsOverridesAsync(containerId);
            settingsChunkingStrategy = overrides?.Chunking?.Strategy ?? "";
            settingsMaxChunkSize = overrides?.Chunking?.MaxChunkSize;
            settingsOverlap = overrides?.Chunking?.Overlap;
            settingsEmbeddingProvider = overrides?.Embedding?.Provider ?? "";
            settingsEmbeddingModel = overrides?.Embedding?.Model ?? "";
            settingsEmbeddingDimensions = overrides?.Embedding?.Dimensions;
            settingsSearchMode = overrides?.Search?.Mode ?? "";
            settingsTopK = overrides?.Search?.TopK;
            settingsMinScore = overrides?.Search?.MinimumScore;

            // Filesystem permission toggles
            settingsAllowUpload = filesystemConfig?.AllowUpload ?? true;
            settingsAllowDelete = filesystemConfig?.AllowDelete ?? true;
            settingsAllowCreateFolder = filesystemConfig?.AllowCreateFolder ?? true;
        }
        catch (Exception ex)
        {
            settingsError = $"Failed to load settings: {ex.Message}";
        }
        finally
        {
            settingsLoading = false;
        }
    }

    private async Task SaveSettings()
    {
        if (!Guid.TryParse(ContainerId, out var containerId)) return;

        settingsSaving = true;
        settingsSaved = false;
        settingsError = null;

        try
        {
            var overrides = new ContainerSettingsOverrides
            {
                Chunking = (!string.IsNullOrEmpty(settingsChunkingStrategy) || settingsMaxChunkSize.HasValue || settingsOverlap.HasValue)
                    ? new ChunkingSettings
                    {
                        Strategy = string.IsNullOrEmpty(settingsChunkingStrategy) ? globalChunkingStrategy : settingsChunkingStrategy,
                        MaxChunkSize = settingsMaxChunkSize ?? globalMaxChunkSize,
                        Overlap = settingsOverlap ?? globalOverlap
                    }
                    : null,
                Embedding = (!string.IsNullOrEmpty(settingsEmbeddingProvider) || !string.IsNullOrEmpty(settingsEmbeddingModel) || settingsEmbeddingDimensions.HasValue)
                    ? new EmbeddingSettings
                    {
                        Provider = string.IsNullOrEmpty(settingsEmbeddingProvider) ? globalEmbeddingProvider : settingsEmbeddingProvider,
                        Model = string.IsNullOrEmpty(settingsEmbeddingModel) ? globalEmbeddingModel : settingsEmbeddingModel,
                        Dimensions = settingsEmbeddingDimensions ?? globalEmbeddingDimensions
                    }
                    : null,
                Search = (!string.IsNullOrEmpty(settingsSearchMode) || settingsTopK.HasValue || settingsMinScore.HasValue)
                    ? new SearchSettings
                    {
                        Mode = string.IsNullOrEmpty(settingsSearchMode) ? globalSearchMode : settingsSearchMode,
                        TopK = settingsTopK ?? globalTopK,
                        MinimumScore = settingsMinScore ?? globalMinScore
                    }
                    : null
            };

            await ContainerStore.SaveSettingsOverridesAsync(containerId, overrides);

            // Persist Filesystem permission toggles
            if (container?.ConnectorType == ConnectorType.Filesystem && filesystemConfig is not null)
            {
                var updatedConfig = filesystemConfig with
                {
                    AllowDelete = settingsAllowDelete,
                    AllowUpload = settingsAllowUpload,
                    AllowCreateFolder = settingsAllowCreateFolder
                };
                var configJson = System.Text.Json.JsonSerializer.Serialize(updatedConfig,
                    new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase });
                await ContainerStore.UpdateConnectorConfigAsync(containerId, configJson);
                filesystemConfig = updatedConfig;
                container = container with { ConnectorConfig = configJson };
            }

            settingsSaved = true;
        }
        catch (Exception ex)
        {
            settingsError = $"Failed to save settings: {ex.Message}";
        }
        finally
        {
            settingsSaving = false;
        }
    }

    private async Task ClearSettings()
    {
        if (!Guid.TryParse(ContainerId, out var containerId)) return;

        settingsSaving = true;
        settingsSaved = false;
        settingsError = null;

        try
        {
            await ContainerStore.SaveSettingsOverridesAsync(containerId, new ContainerSettingsOverrides());
            settingsChunkingStrategy = "";
            settingsMaxChunkSize = null;
            settingsOverlap = null;
            settingsEmbeddingProvider = "";
            settingsEmbeddingModel = "";
            settingsEmbeddingDimensions = null;
            settingsSearchMode = "";
            settingsTopK = null;
            settingsMinScore = null;
            settingsSaved = true;
        }
        catch (Exception ex)
        {
            settingsError = $"Failed to clear settings: {ex.Message}";
        }
        finally
        {
            settingsSaving = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        ProgressNotifier.ProgressReceived -= OnProgressReceived;
        FileChangeNotifier.FileChanged -= OnFileChanged;
        if (jsModule is not null)
        {
            try { await jsModule.DisposeAsync(); }
            catch (JSDisconnectedException) { }
        }
        dotNetRef?.Dispose();
    }

    // DTOs
    private record BrowseEntryDto(string Name, string Path, bool IsFolder, long? SizeBytes, DateTime? LastModified, string? Status, string? Id);
    private record UploadResponseDto(string? BatchId, List<UploadedDocDto> Documents, int TotalCount, int SuccessCount);
    private record UploadedDocDto(string DocumentId, string? JobId, string FileName, long SizeBytes, string Path, string? Error);
    private record BreadcrumbItem(string Name, string Path);

