# Connapse Environment Variables
# Copy this file to .env and customize for your environment
# ⚠️ NEVER commit the .env file to version control

# ============================================================================
# ⚠️ SECURITY WARNING
# ============================================================================
# These are DEVELOPMENT-ONLY defaults. They are NOT secure for any deployment.
#
# For ANY deployment (even on private networks):
# 1. Generate strong random passwords (20+ characters)
# 2. Never reuse passwords across services
# 3. Store .env file securely (not in git)
# 4. Use secrets management (Azure Key Vault, AWS Secrets Manager, etc.) in production
#
# Generate strong passwords:
#   Linux/Mac: openssl rand -base64 32
#   PowerShell: -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
# ============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
POSTGRES_PASSWORD=connapse_dev
# ⚠️ CHANGE THIS! Default password is publicly known.
# Used by PostgreSQL container and web app connection string.

# Advanced PostgreSQL settings (optional)
# POSTGRES_DB=connapse
# POSTGRES_USER=connapse

# ----------------------------------------------------------------------------
# Object Storage (MinIO - S3-compatible)
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=connapse_dev
MINIO_ROOT_PASSWORD=connapse_dev_secret
# ⚠️ CHANGE BOTH! These are MinIO admin credentials.
# Used for file storage (uploaded documents).

# ----------------------------------------------------------------------------
# Application Settings (optional overrides)
# ----------------------------------------------------------------------------
# Uncomment to override appsettings.json values

# ASP.NET Core environment
# ASPNETCORE_ENVIRONMENT=Development

# Embedding provider (Ollama, OpenAI, Azure)
# Knowledge__Embedding__Provider=Ollama
# Knowledge__Embedding__BaseUrl=http://ollama:11434

# OpenAI settings (if using OpenAI provider)
# Knowledge__Embedding__OpenAI__ApiKey=sk-...
# Knowledge__Embedding__OpenAI__Model=text-embedding-3-small

# Azure OpenAI settings (if using Azure provider)
# Knowledge__Embedding__Azure__Endpoint=https://your-resource.openai.azure.com
# Knowledge__Embedding__Azure__ApiKey=...
# Knowledge__Embedding__Azure__DeploymentName=text-embedding-ada-002

# ----------------------------------------------------------------------------
# Auth / JWT Settings (v0.2.0+)
# ----------------------------------------------------------------------------
# Admin account auto-seed on first startup
# CONNAPSE_ADMIN_EMAIL=admin@example.com
# CONNAPSE_ADMIN_PASSWORD=YourSecureAdminPassword123!

# JWT signing secret — generate with: openssl rand -base64 64
# ⚠️ REQUIRED in production. Must be at least 32 characters.
# Identity__Jwt__Secret=replace-with-a-long-random-secret-at-least-64-chars
# Identity__Jwt__Issuer=Connapse                        # JWT issuer claim
# Identity__Jwt__Audience=Connapse                      # JWT audience claim
# Identity__Jwt__AccessTokenExpiryMinutes=90            # Access token lifetime
# Identity__Jwt__RefreshTokenExpiryDays=30              # Refresh token lifetime
# Identity__Cookie__SlidingExpirationDays=14            # Cookie session lifetime

# ----------------------------------------------------------------------------
# LLM Provider Settings (v0.3.0+)
# ----------------------------------------------------------------------------
# Knowledge__Llm__Provider=Ollama                       # Ollama | OpenAI | AzureOpenAI | Anthropic
# Knowledge__Llm__BaseUrl=http://ollama:11434           # Base URL (Ollama/OpenAI)
# Knowledge__Llm__Model=llama2                          # Model name
# Knowledge__Llm__ApiKey=                               # API key (OpenAI/AzureOpenAI/Anthropic)
# Knowledge__Llm__AzureDeploymentName=                  # Azure OpenAI deployment name
# Knowledge__Llm__Temperature=0.7                       # Generation temperature
# Knowledge__Llm__MaxTokens=2048                        # Max output tokens

# ----------------------------------------------------------------------------
# Search Settings
# ----------------------------------------------------------------------------
# Knowledge__Search__Mode=Hybrid                        # Semantic | Keyword | Hybrid
# Knowledge__Search__TopK=10                            # Default result count
# Knowledge__Search__FusionMethod=ConvexCombination     # ConvexCombination | DBSF
# Knowledge__Search__FusionAlpha=0.5                    # Semantic weight (0.0-1.0)
# Knowledge__Search__AutoCut=false                      # Auto-trim after largest score gap
# Knowledge__Search__MinimumScore=0                     # Minimum similarity score floor

# ----------------------------------------------------------------------------
# Chunking Settings
# ----------------------------------------------------------------------------
# Knowledge__Chunking__Strategy=Semantic                # Semantic | Fixed
# Knowledge__Chunking__MaxTokens=512                    # Max tokens per chunk
# Knowledge__Chunking__Overlap=50                       # Overlap tokens between chunks

# ----------------------------------------------------------------------------
# Upload Settings
# ----------------------------------------------------------------------------
# Knowledge__Upload__MaxFileSizeBytes=104857600         # Max upload size (default 100MB)
# Knowledge__Upload__ConcurrentIngestions=4             # Parallel ingestion workers

# ----------------------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------------------
# RateLimiting__AuthPermitLimit=10                      # Auth endpoint requests per window
# RateLimiting__AuthWindowSeconds=60                    # Auth rate limit window (seconds)
# RateLimiting__ApiPermitLimit=200                      # API endpoint requests per window
# RateLimiting__ApiWindowSeconds=60                     # API rate limit window (seconds)
# RateLimiting__McpPermitLimit=600                      # MCP endpoint requests per window
# RateLimiting__McpWindowSeconds=60                     # MCP rate limit window (seconds)

# ----------------------------------------------------------------------------
# Cloud Identity (v0.3.0+)
# ----------------------------------------------------------------------------
# AWS IAM Identity Center (SSO)
# Identity__AwsSso__IssuerUrl=                          # IAM Identity Center issuer URL
# Identity__AwsSso__Region=us-east-1                    # AWS region for SSO

# Azure AD (OAuth2 + PKCE)
# Identity__AzureAd__ClientId=                          # Azure AD app registration client ID
# Identity__AzureAd__TenantId=                          # Azure AD tenant ID
# Identity__AzureAd__ClientSecret=                      # Azure AD client secret (confidential client)

# ----------------------------------------------------------------------------
# Development Tools (optional)
# ----------------------------------------------------------------------------
# Ollama API endpoint (only if running Ollama separately)
# OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------------------------
# Notes
# ----------------------------------------------------------------------------
# - This file uses docker-compose variable substitution syntax
# - Values here override docker-compose.yml defaults
# - For local development, you can keep defaults (they're already insecure anyway)
# - For any networked deployment, CHANGE ALL CREDENTIALS
# - See SECURITY.md for full security considerations
# - For the full configuration reference, see docs/deployment.md
